# 显示帮助
cmd_help() {
    cat << EOF
Harness Engineering v$VERSION - Agent-first Repository Harness

核心理念: "Humans steer. Agents execute."

用法: harness <command> [options]

核心命令:
  init                              初始化项目结构
  plan create <title> <desc>        创建执行计划
  plan add-task <id> <title> <desc> 添加任务到计划
  run [plan_id]                     启动 agent 主循环

查询命令:
  plan list                         列出所有执行计划
  plan show <id>                    查看计划详情
  task show <id>                    查看任务详情

质量命令:
  check                             运行所有质量检查（lint + typecheck + test + docs）
  check --only lint                 只跑 lint
  check --only typecheck            只跑类型检查
  check --only test                 只跑测试
  check --only harness-docs         只检查文档完整性
  check --skip test                 跳过测试
  check --json                      输出 JSON 报告（适合 CI）

工作流示例:
  # 1. 初始化项目
  harness init

  # 2. 编写产品需求文档
  vim .harness/docs/product/feature.md

  # 3. 创建执行计划
  harness plan create "实现用户认证" "添加 JWT 认证系统"

  # 4. 添加任务（可选，agent 也可以自动分解）
  harness plan add-task EP-xxx "实现登录接口" "POST /api/login"

  # 5. 启动 agent 主循环
  export ANTHROPIC_API_KEY=your_key
  harness run

  # Agent 会自动:
  # - 读取仓库文档
  # - 创建工作分支
  # - 实现代码
  # - 运行测试
  # - 创建 PR
  # - 响应 review

更多信息: https://github.com/PIGU-PPPgu/harness-skill-v2
EOF
}

# 显示版本
cmd_version() {
    echo "Harness Engineering v$VERSION"
}

# 主函数
main() {
    if [ $# -eq 0 ]; then
        cmd_help
        exit 0
    fi

    case "$1" in
        init)
            cmd_init
            ;;
        plan)
            shift
            case "${1:-}" in
                create)
                    shift
                    cmd_plan_create "$@"
                    ;;
                add-task)
                    shift
                    cmd_plan_add_task "$@"
                    ;;
                list|show)
                    log_warning "功能开发中"
                    ;;
                *)
                    log_error "未知的 plan 命令: ${1:-}"
                    exit 1
                    ;;
            esac
            ;;
        run)
            shift
            cmd_run "$@"
            ;;
        check)
            shift
            cmd_check "$@"
            ;;
        swarm)
            shift
            case "${1:-}" in
                start)
                    shift
                    cmd_swarm_start "$@"
                    ;;
                status|stop|pause|resume|wait)
                    log_warning "⚠️  'swarm' 命令已废弃，请使用 'harness run'"
                    ;;
                *)
                    log_error "未知的 swarm 命令: ${1:-}"
                    exit 1
                    ;;
            esac
            ;;
        audit)
            cmd_audit
            ;;
        enforce)
            shift
            cmd_enforce "$@"
            ;;
        help|--help|-h)
            cmd_help
            ;;
        version|--version|-v)
            cmd_version
            ;;
        *)
            log_error "未知命令: $1"
            echo "使用 'harness help' 查看帮助"
            exit 1
            ;;
    esac
}

main "$@"
