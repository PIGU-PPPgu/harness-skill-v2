#!/usr/bin/env bash

set -euo pipefail

VERSION="2.2.0"
HARNESS_DIR=".harness"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# 安装后 Python 模块在 ../lib/harness/，开发时在 ./src/
if [ -d "${SCRIPT_DIR}/../lib/harness" ]; then
  SRC="${SCRIPT_DIR}/../lib/harness"
else
  SRC="$SCRIPT_DIR/src"
fi

RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; BLUE='\033[0;34m'; NC='\033[0m'
info()    { echo -e "${BLUE}ℹ${NC} $*"; }
success() { echo -e "${GREEN}✓${NC} $*"; }
warn()    { echo -e "${YELLOW}⚠${NC} $*"; }
error()   { echo -e "${RED}✗${NC} $*"; exit 1; }

# ── init ──────────────────────────────────────────────────────────────────────
cmd_init() {
    python3 "$SRC/harness_runtime.py" init
}

# ── plan ──────────────────────────────────────────────────────────────────────
cmd_plan_create() {
    [ $# -lt 2 ] && error "Usage: harness plan create <title> <description>"
    python3 "$SRC/harness_runtime.py" create-plan "$1" "$2"
}

cmd_plan_task_add() {
    [ $# -lt 3 ] && error "Usage: harness plan task add <plan_id> <title> <description> [dep1,dep2,...]"
    local deps="${4:-}"
    python3 "$SRC/harness_runtime.py" add-task "$1" "$2" "$3" ${deps:+"$deps"}
}

cmd_plan_list() {
    local plans_dir="$HARNESS_DIR/docs/plans/active"
    if [ ! -d "$plans_dir" ] || [ -z "$(ls "$plans_dir"/*.json 2>/dev/null)" ]; then
        info "No active plans. Run: harness plan create <title> <desc>"
        return
    fi
    echo ""
    echo "Active plans:"
    for f in "$plans_dir"/*.json; do
        local id tasks done
        id=$(python3 -c "import json,sys; d=json.load(open('$f')); print(d['id'])")
        tasks=$(python3 -c "import json,sys; d=json.load(open('$f')); print(len(d['tasks']))")
        done=$(python3 -c "import json,sys; d=json.load(open('$f')); print(sum(1 for t in d['tasks'] if t['status']=='done'))")
        title=$(python3 -c "import json,sys; d=json.load(open('$f')); print(d['title'])")
        echo "  $id  [$done/$tasks]  $title"
    done
    echo ""
}

# ── run ───────────────────────────────────────────────────────────────────────
cmd_run() {
    local plan_id="${1:-}"
    if [ -z "$plan_id" ]; then
        plan_id=$(ls -t "$HARNESS_DIR/docs/plans/active"/*.json 2>/dev/null \
            | head -1 | xargs basename 2>/dev/null | sed 's/.json$//' || true)
        [ -z "$plan_id" ] && error "No active plan. Run: harness plan create <title> <desc>"
    fi
    [ -z "${ANTHROPIC_API_KEY:-}" ] && error "ANTHROPIC_API_KEY not set"
    info "Starting agent loop for plan: $plan_id"
    python3 "$SRC/agent_loop.py" "$plan_id"
}

# ── check ─────────────────────────────────────────────────────────────────────
cmd_check() {
    python3 "$SRC/harness_check.py" "$@"
}

# ── audit ─────────────────────────────────────────────────────────────────────
cmd_audit() {
    echo ""
    info "Agent Readability Audit"
    echo "────────────────────────────────────────────────"
    python3 "$SRC/checks/audit.py" "$@"
}

# ── garden ────────────────────────────────────────────────────────────────────
cmd_garden() {
    echo ""
    info "Garden — documentation & code hygiene"
    echo "────────────────────────────────────────────────"
    local mode="all"
    case "${1:-}" in
        --docs-only) mode="docs" ;;
        --code-only) mode="code" ;;
    esac
    python3 -c "
import sys; sys.path.insert(0,'$SRC')
from checks.garden import run_garden, print_garden
from pathlib import Path
report = run_garden(Path('.'), '$mode')
print_garden(report)
sys.exit(0 if report.passed else 1)
"
}

# ── golden-rules ──────────────────────────────────────────────────────────────
cmd_golden_rules() {
    echo ""
    info "Golden Rules — code pattern check"
    echo "────────────────────────────────────────────────"
    python3 -c "
import sys; sys.path.insert(0,'$SRC')
from checks.golden_rules import run_golden_rules, print_golden_rules
from pathlib import Path
report = run_golden_rules(Path('.'))
print_golden_rules(report)
sys.exit(0 if report.passed else 1)
"
}

# ── logs ──────────────────────────────────────────────────────────────────────
cmd_logs() {
    local follow=false
    [ "${1:-}" = "--follow" ] && follow=true
    local log_dir="$HARNESS_DIR/logs"
    [ ! -d "$log_dir" ] && error "No logs directory. Run: harness init"
    if [ "$follow" = true ]; then
        tail -f "$log_dir"/*.log 2>/dev/null || info "No log files yet"
    else
        for f in "$log_dir"/*.log; do
            [ -f "$f" ] && echo "=== $(basename "$f") ===" && tail -20 "$f"
        done
    fi
}

# ── help ──────────────────────────────────────────────────────────────────────
cmd_help() {
    cat << EOF

Harness Engineering v$VERSION
"Humans steer. Agents execute."

SETUP
  init                              Generate CLAUDE.md, AGENTS.md, .harness/docs/

PLANNING
  plan create <title> <desc>        Create execution plan (JSON + state machine)
  plan list                         List active plans
  plan task add <plan_id> <title> <desc> [deps]
                                    Add task to plan (deps: comma-separated task IDs)

EXECUTION
  run [plan_id]                     Start agent main loop (needs ANTHROPIC_API_KEY)

QUALITY
  check                             Run lint + typecheck + test + doc integrity
  check --only <lint|test|typecheck|harness-docs>
  check --skip <name>
  check --json                      JSON output for CI

  audit                             Agent readability score (0-100)
  audit --score                     Score only

  garden                            Doc freshness + code duplication scan
  garden --docs-only
  garden --code-only

  golden-rules                      Code pattern violations
  golden-rules --check

OBSERVABILITY
  logs [--follow]                   View agent logs

WORKFLOW
  1. harness init
  2. Edit CLAUDE.md + .harness/docs/architecture/overview.md
  3. harness plan create "Feature X" "Description"
  4. Use Claude Code or Codex — they read CLAUDE.md/AGENTS.md automatically
  5. harness check && harness audit   (before merging PR)

EOF
}

cmd_version() { echo "Harness Engineering v$VERSION"; }

# ── main ──────────────────────────────────────────────────────────────────────
main() {
    [ $# -eq 0 ] && cmd_help && exit 0
    case "$1" in
        init)           cmd_init ;;
        plan)           shift
                        case "${1:-}" in
                            create)   shift; cmd_plan_create "$@" ;;
                            list)     cmd_plan_list ;;
                            task)     shift
                                      case "${1:-}" in
                                          add) shift; cmd_plan_task_add "$@" ;;
                                          *)   error "Unknown plan task command: ${1:-}" ;;
                                      esac ;;
                            *)        error "Unknown plan command: ${1:-}" ;;
                        esac ;;
        run)            shift; cmd_run "$@" ;;
        check)          shift; cmd_check "$@" ;;
        audit)          shift; cmd_audit "$@" ;;
        garden)         shift; cmd_garden "$@" ;;
        golden-rules)   shift; cmd_golden_rules "$@" ;;
        logs)           shift; cmd_logs "$@" ;;
        help|--help|-h) cmd_help ;;
        version|--version|-v) cmd_version ;;
        # 兼容旧命令
        swarm|tasks|agent|enforce|docs)
                        warn "'$1' is deprecated. See: harness help" ;;
        *)              error "Unknown command: $1. Run: harness help" ;;
    esac
}

main "$@"
