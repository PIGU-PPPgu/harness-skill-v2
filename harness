#!/usr/bin/env bash

set -euo pipefail

VERSION="2.1.0"
# 注意：版本与 CHANGELOG.md 保持同步
HARNESS_DIR=".harness"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PYTHON_RUNTIME="$SCRIPT_DIR/src/harness_runtime.py"
AGENT_LOOP="$SCRIPT_DIR/src/agent_loop.py"
HARNESS_CHECK="$SCRIPT_DIR/src/harness_check.py"

# 颜色定义
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# 日志函数
log_info() {
    echo -e "${BLUE}[INFO]${NC} $1"
}

log_success() {
    echo -e "${GREEN}[SUCCESS]${NC} $1"
}

log_warning() {
    echo -e "${YELLOW}[WARNING]${NC} $1"
}

log_error() {
    echo -e "${RED}[ERROR]${NC} $1"
}

# 初始化项目结构
cmd_init() {
    log_info "初始化 Harness Engineering 项目结构..."

    # 调用 Python 运行时
    if [ -f "$PYTHON_RUNTIME" ]; then
        python3 "$PYTHON_RUNTIME" init
    else
        log_error "Python runtime not found: $PYTHON_RUNTIME"
        exit 1
    fi

    log_success "项目结构初始化完成"
    log_info "下一步:"
    echo "  1. 在 .harness/docs/product/ 创建产品需求文档"
    echo "  2. 运行 'harness plan create' 创建执行计划"
    echo "  3. 运行 'harness run' 启动 agent 主循环"
}

# 创建执行计划
cmd_plan_create() {
    if [ $# -lt 2 ]; then
        log_error "用法: harness plan create <title> <description>"
        exit 1
    fi

    local title="$1"
    local description="$2"

    log_info "创建执行计划: $title"

    if [ -f "$PYTHON_RUNTIME" ]; then
        python3 "$PYTHON_RUNTIME" create-plan "$title" "$description"
    else
        log_error "Python runtime not found"
        exit 1
    fi
}

# 添加任务到计划
cmd_plan_add_task() {
    if [ $# -lt 3 ]; then
        log_error "用法: harness plan add-task <plan_id> <title> <description>"
        exit 1
    fi

    local plan_id="$1"
    local title="$2"
    local description="$3"

    log_info "添加任务到计划 $plan_id"

    # TODO: 调用 Python 运行时
    log_warning "功能开发中"
}

# 运行 agent 主循环
cmd_run() {
    local plan_id="${1:-}"

    if [ -z "$plan_id" ]; then
        # 查找最新的活跃计划
        plan_id=$(ls -t "$HARNESS_DIR/docs/plans/active"/*.json 2>/dev/null | head -1 | xargs basename | sed 's/.json$//')
        if [ -z "$plan_id" ]; then
            log_error "未找到活跃的执行计划"
            log_info "请先运行: harness plan create <title> <description>"
            exit 1
        fi
    fi

    log_info "启动 agent 主循环"
    log_info "执行计划: $plan_id"

    if [ ! -f "$AGENT_LOOP" ]; then
        log_error "Agent loop not found: $AGENT_LOOP"
        exit 1
    fi

    # 检查 API key
    if [ -z "${ANTHROPIC_API_KEY:-}" ]; then
        log_error "ANTHROPIC_API_KEY not set"
        log_info "请设置环境变量: export ANTHROPIC_API_KEY=your_key"
        exit 1
    fi

    python3 "$AGENT_LOOP" "$plan_id"
}

# 启动智能体团队（废弃，保留兼容性）
cmd_swarm_start() {
    log_warning "⚠️  'swarm start' 已废弃"
    log_info "Harness Engineering 使用单主循环，不是多角色流水线"
    log_info "请使用: harness run [plan_id]"
    echo ""
    read -p "是否继续使用新命令? (y/n) " -n 1 -r
    echo
    if [[ $REPLY =~ ^[Yy]$ ]]; then
        cmd_run "$@"
    fi
}

