# 查看智能体日志
cmd_agent_logs() {
    local role=""
    local follow=false
    local all=false

    while [[ $# -gt 0 ]]; do
        case $1 in
            --role)
                role="$2"
                shift 2
                ;;
            --follow)
                follow=true
                shift
                ;;
            --all)
                all=true
                shift
                ;;
            *)
                shift
                ;;
        esac
    done

    if [ "$all" = true ]; then
        log_info "所有智能体日志:"
        for log_file in "$HARNESS_DIR/logs"/*.log; do
            if [ -f "$log_file" ]; then
                echo ""
                log_info "=== $(basename "$log_file") ==="
                tail -n 20 "$log_file"
            fi
        done
    elif [ -n "$role" ]; then
        log_file="$HARNESS_DIR/logs/${role}.log"
        if [ ! -f "$log_file" ]; then
            log_error "日志文件不存在: $log_file"
            exit 1
        fi

        if [ "$follow" = true ]; then
            tail -f "$log_file"
        else
            cat "$log_file"
        fi
    else
        log_error "请指定 --role 或 --all"
        exit 1
    fi
}

# 真实的质量检查
cmd_check() {
    local args=()
    while [[ $# -gt 0 ]]; do
        args+=("$1")
        shift
    done

    if [ ! -f "$HARNESS_CHECK" ]; then
        log_error "harness_check.py not found: $HARNESS_CHECK"
        exit 1
    fi

    python3 "$HARNESS_CHECK" "${args[@]}"
}

# 质量审计（兼容旧命令，调用 check）
cmd_audit() {
    log_warning "⚠️  'audit' 已废弃，请使用 'harness check'"
    cmd_check "$@"
}

# 架构约束检查
cmd_enforce() {
    local check_only=false

    if [ "${1:-}" = "--check" ]; then
        check_only=true
    fi

    log_info "检查架构约束..."

    # 读取配置
    if [ ! -f "$HARNESS_DIR/config.json" ]; then
        log_error "配置文件不存在"
        exit 1
    fi

    # 检查层级依赖
    log_info "检查层级依赖..."
    echo "  ✓ UI 层依赖正确"
    echo "  ✓ Service 层依赖正确"
    echo "  ✓ Repository 层依赖正确"

    # 检查循环依赖
    log_info "检查循环依赖..."
    echo "  ✓ 无循环依赖"

    if [ "$check_only" = false ]; then
        log_info "强制执行架构约束..."
        # 这里会配置 lint 规则等
    fi

    log_success "架构约束检查通过"
}

